# PDF Service Environment Variables
# Copy to .env and fill in values

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=production

# ── Internal service authentication ───────────────────────────────────────
# Must match PDF_SERVICE_SECRET in java-backend application.yml
PDF_SERVICE_SECRET=change-me-in-production

# ── Cloudflare R2 ─────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=forge-files
