# ============================================================
# Backend Production Environment Variables
# Copy this to: /var/www/forgedas/backend/.env
# Update the values marked with <CHANGE_THIS>
# ============================================================

# Database
# Railway: use private DB URL to avoid egress fees
# DATABASE_PRIVATE_URL=postgresql://user:pass@<private-host>:5432/dbname
DB_NAME=forgedas
DB_USER=postgres
DB_PASSWORD=<CHANGE_THIS_TO_DB_PASSWORD>
DB_HOST=localhost
DB_PORT=5432

# JWT Secret (generate a strong random key)
JWT_SECRET=<CHANGE_THIS_TO_RANDOM_SECRET>

# Server
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://YOUR_DOMAIN.com

# Admin Account (auto-created/reset on every deploy)
ADMIN_EMAIL=admin@forgedas.com
ADMIN_PASSWORD=<CHANGE_THIS_TO_ADMIN_PASSWORD>
ADMIN_NAME=Admin

# SMTP Email Configuration (required for Send to Client / Send to Vendor)
# Use EMAIL_* variables (SMTP_* also accepted for backwards compatibility)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=<CHANGE_THIS_TO_APP_PASSWORD>
EMAIL_FROM=noreply@yourdomain.com
# Resend alternative:
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_USER=resend
# EMAIL_PASS=re_your_api_key
# EMAIL_FROM=onboarding@resend.dev
