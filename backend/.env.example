# Environment
NODE_ENV=development
PORT=5000

# Database
# Railway: prefer private URL to avoid egress (do not use DATABASE_PUBLIC_URL)
# DATABASE_PRIVATE_URL=postgresql://user:pass@<private-host>:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forgedas
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Admin Account (auto-created on startup)
# If not set, defaults to admin@forgedas.com / admin1234
ADMIN_EMAIL=admin@forgedas.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email / SMTP
# Leave blank in development — Ethereal auto-test account is used automatically.
# Emails are viewable at https://ethereal.email/messages (URL logged to console).
#
# Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM=your@gmail.com
#
# Resend (recommended free tier):
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_USER=resend
# EMAIL_PASS=re_your_api_key
# EMAIL_FROM=onboarding@resend.dev
#
# Outlook / Office 365:
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_USER=your@outlook.com
# EMAIL_PASS=your-password
# EMAIL_FROM=your@outlook.com
