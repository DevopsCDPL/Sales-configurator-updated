AI_GATEWAY_PORT=4001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Forge backend (for command routing)
FORGE_BACKEND_URL=http://localhost:5000
FORGE_SERVICE_TOKEN=

# --- Production hardening ---------------------------------------------------

# Mock mode (skip OpenAI + skip backend POST). 1 = on. Leave unset in prod.
AI_MOCK=

# Persistent session store. Leave empty for in-memory (dev / single instance).
REDIS_URL=
AI_SESSION_TTL_MS=600000

# Logging. error | warn | info | debug | trace
LOG_LEVEL=info

# Rate limit per user (key = JWT sub or service-header user id).
AI_RATE_WINDOW_MS=60000
AI_RATE_MAX=30

# Timeouts (ms).
AI_OPENAI_TIMEOUT_MS=12000
AI_BACKEND_TIMEOUT_MS=15000
AI_HTTP_TIMEOUT_MS=15000

# Auth. ONE of these MUST be set in production:
#   AI_AUTH_SECRET   = HS256 secret used to verify Bearer JWTs
#   AI_SERVICE_TOKEN = shared secret for backend-proxied requests
#                       (callers send X-AI-Service-Token + X-AI-User-Id + X-AI-User-Role)
# Dev only \u2014 trusts req.body.user (NEVER set in prod):
#   AI_AUTH_DISABLED=1
AI_AUTH_SECRET=
AI_SERVICE_TOKEN=
AI_AUTH_DISABLED=

# CORS allow-list. Default echoes the request origin (suitable for dev only).
AI_CORS_ORIGIN=
